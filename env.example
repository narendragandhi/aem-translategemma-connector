# AEM TranslateGemma Connector - Environment Variables Configuration
# 
# For AEM as a Cloud Service, configure these via Cloud Manager environment variables
# For local development, set these in your IDE run configuration or .env file
#
# ============================================================================
# REQUIRED VARIABLES
# ============================================================================
GCP_PROJECT_ID=your-gcp-project-id

# ============================================================================
# GOOGLE CLOUD SETTINGS
# ============================================================================
# GCP_LOCATION: Google Cloud region for Vertex AI (default: us-central1)
GCP_LOCATION=us-central1

# GOOGLE_APPLICATION_CREDENTIALS: Path to service account JSON key
# For AEM Cloud Service: Use Cloud Manager secret management
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ============================================================================
# TRANSLATION SETTINGS
# ============================================================================
# TRANSLATION_ENABLED: Enable/disable translation service
TRANSLATION_ENABLED=true

# DEFAULT_SOURCE_LANG: Default source language code (ISO 639-1)
DEFAULT_SOURCE_LANG=en

# DEFAULT_TARGET_LANG: Default target language code (ISO 639-1)
DEFAULT_TARGET_LANG=es

# DEFAULT_CATEGORY: Default content category
DEFAULT_CATEGORY=general

# MAX_TRANSLATION_LENGTH: Maximum characters per translation request
MAX_TRANSLATION_LENGTH=5000

# ============================================================================
# CONNECTION SETTINGS
# ============================================================================
# CONNECTION_TIMEOUT: Connection timeout in seconds
CONNECTION_TIMEOUT=30

# READ_TIMEOUT: Read timeout in seconds
READ_TIMEOUT=60

# REQUEST_TIMEOUT_SECONDS: Overall request timeout
REQUEST_TIMEOUT_SECONDS=120

# ============================================================================
# TRANSLATION PROVIDER
# ============================================================================
# TRANSLATION_PROVIDER: Primary translation provider
# Options: translategemma, google_translate, deepl, microsoft, openai, ollama
TRANSLATION_PROVIDER=translategemma

# TRANSLATION_API_KEY: API key for DeepL, Microsoft, OpenAI
# For AEM Cloud Service: Store as Cloud Manager secret
TRANSLATION_API_KEY=

# MODEL_NAME: Translation model name
MODEL_NAME=google/gemma-4-26b-a4b-it

# ============================================================================
# OLLAMA SETTINGS (for local models)
# ============================================================================
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama2

# ============================================================================
# TRANSLATION MEMORY SETTINGS
# ============================================================================
# TM_ENABLED: Enable translation memory lookup
TM_ENABLED=true

# TM_MIN_SCORE: Minimum match score (0.0-1.0)
TM_MIN_SCORE=0.85

# TM_STORE_ENABLED: Auto-store translations to TM
TM_STORE_ENABLED=true

# ============================================================================
# FALLBACK PROVIDERS
# ============================================================================
# FALLBACK_ENABLED: Enable fallback to backup providers
FALLBACK_ENABLED=true

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================
# PARALLEL_TRANSLATIONS: Concurrent translation requests
PARALLEL_TRANSLATIONS=3

# RETRY_ATTEMPTS: Number of retry attempts on failure
RETRY_ATTEMPTS=2

# BATCH_SIZE: Number of texts per batch request
BATCH_SIZE=10

# ============================================================================
# RESILIENCE SETTINGS (v1.2.0+)
# ============================================================================
# RETRY_MAX_ATTEMPTS: Maximum retry attempts with exponential backoff
RETRY_MAX_ATTEMPTS=3

# RETRY_WAIT_DURATION_MS: Initial wait between retries (ms)
RETRY_WAIT_DURATION_MS=1000

# CIRCUIT_BREAKER_FAILURE_RATE_THRESHOLD: % failures to open circuit
CIRCUIT_BREAKER_FAILURE_RATE_THRESHOLD=50

# CIRCUIT_BREAKER_SLOW_CALL_RATE_THRESHOLD: % slow calls to open circuit
CIRCUIT_BREAKER_SLOW_CALL_RATE_THRESHOLD=100

# CIRCUIT_BREAKER_SLOW_CALL_DURATION_MS: Slow call threshold (ms)
CIRCUIT_BREAKER_SLOW_CALL_DURATION_MS=5000

# CIRCUIT_BREAKER_WAIT_DURATION_SECONDS: Time circuit stays open (seconds)
CIRCUIT_BREAKER_WAIT_DURATION_SECONDS=30

# ============================================================================
# CACHING SETTINGS (v1.2.0+)
# ============================================================================
# ENABLE_CACHING: Enable translation caching
ENABLE_CACHING=true

# CACHE_MAX_SIZE: Maximum cache entries
CACHE_MAX_SIZE=1000

# CACHE_EXPIRE_AFTER_MINUTES: Cache TTL in minutes
CACHE_EXPIRE_AFTER_MINUTES=60

# ============================================================================
# MONITORING SETTINGS (v1.2.0+)
# ============================================================================
# ENABLE_METRICS: Enable metrics collection
ENABLE_METRICS=true

# METRICS_ENABLED: Enable detailed metrics reporting
METRICS_ENABLED=false

# ============================================================================
# CONTENT TYPES
# ============================================================================
# SUPPORTED_CONTENT_TYPES: Comma-separated content types
SUPPORTED_CONTENT_TYPES=html,plaintext,json,xml

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# VISUAL_CONTEXT_ENABLED: Capture screenshots for translators
VISUAL_CONTEXT_ENABLED=false

# DAM_TRANSLATION_ENABLED: Translate DAM asset metadata
DAM_TRANSLATION_ENABLED=true

# I18N_TRANSLATION_ENABLED: Translate i18n dictionaries
I18N_TRANSLATION_ENABLED=true

# ============================================================================
# SUPPORTED LANGUAGES
# ============================================================================
# SUPPORTED_LANGUAGES: Comma-separated language codes
SUPPORTED_LANGUAGES=en,es,fr,de,it,pt,ru,ja,ko,zh,ar,hi,nl,sv,da,no,fi,pl,tr

# ============================================================================
# EXAMPLE: AEM Cloud Service Configuration via Cloud Manager
# ============================================================================
# 1. Go to Cloud Manager > Environment > Configuration
# 2. Add the following secrets (for sensitive data):
#    - GCP_PROJECT_ID
#    - GOOGLE_APPLICATION_CREDENTIALS (as secret)
#    - TRANSLATION_API_KEY (as secret)
# 3. Add the following variables (non-sensitive):
#    - GCP_LOCATION=us-central1
#    - TRANSLATION_PROVIDER=translategemma
#    - ENABLE_CACHING=true
#    - ENABLE_METRICS=true
#    - RETRY_MAX_ATTEMPTS=3
# ============================================================================
